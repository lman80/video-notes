{
  "name": "video-notes",
  "version": "1.0.2",
  "description": "Local video review & annotation app — drop a video, pause, draw, and take timestamped notes.",
  "author": "Ashton Miller",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "rebuild": "electron-vite build",
    "pack:dir": "electron-vite build && electron-builder --dir",
    "build:mac": "electron-vite build && electron-builder --mac --publish never",
    "build:win": "electron-vite build && electron-builder --win --publish never",
    "build:linux": "electron-vite build && electron-builder --linux --publish never"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.3"
  }
}
